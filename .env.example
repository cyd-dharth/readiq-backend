# Postgres — db name is "postgres", schema is "readiq" (set via search_path in db.py)
DATABASE_URL=postgresql://postgres:root@localhost:5432/postgres
DB_SCHEMA=readiq

# Redis — used to dispatch generation jobs to readiq-agents
REDIS_URL=redis://redis:6379/0
JOB_QUEUE=book_generation

# CORS — space-separated or JSON list of allowed browser origins
CORS_ORIGINS=["http://localhost:4321","http://127.0.0.1:4321"]

# Chat — internal HTTP endpoint on the agents service, and auth for rate limiting
AGENTS_CHAT_URL=http://agents-api:8001/chat
